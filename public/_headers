/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.njakasoa.xyz wss://api.njakasoa.xyz; base-uri 'self'; frame-ancestors 'none'

/images/*
  Cache-Control: public, max-age=31536000, immutable

/game.js
  Cache-Control: public, max-age=3600
